{
  "permissions": {
    "allow": [
      "Bash(npm run typecheck:*)",
      "Bash(npm run format:*)",
      "Bash(.specify/scripts/bash/check-prerequisites.sh:*)",
      "Bash(if [ -d \"/Users/kokiyamaguchi/Documents/projects/git/personal/github.com/YamaguchiKoki/diary/specs/001-reading-notes-display/checklists\" ])",
      "Bash(then echo \"EXISTS\")",
      "Bash(else echo \"NOT_EXISTS\")",
      "Bash(fi)",
      "Bash(git rev-parse:*)",
      "Bash(test:*)",
      "Bash(npm install:*)",
      "Bash(npm run test:*)",
      "Bash(wc:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "mcp__chrome-devtools__list_pages",
      "mcp__chrome-devtools__navigate_page",
      "mcp__chrome-devtools__take_screenshot",
      "Bash(git commit:*)",
      "Bash(find /Users/kokiyamaguchi/Documents/projects/git/personal/github.com/YamaguchiKoki/diary/src -type f \\\\\\( -name \"*.ts\" -o -name \"*.tsx\" \\\\\\) -exec wc -l {} +)",
      "Bash(npm run:*)",
      "mcp__chrome-devtools__emulate"
